<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Route Navigation (Background)"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

            <!-- Route Points List -->
            <TextView
                android:id="@+id/tvPointsList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading route points..."
                android:textSize="12sp"
                android:background="#F0F0F0"
                android:padding="8dp"
                android:layout_marginBottom="8dp" />

            <!-- Route Info -->
            <TextView
                android:id="@+id/tvRouteInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Route Information"
                android:textStyle="bold"
                android:layout_marginTop="8dp" />

            <!-- Signal Container -->
            <LinearLayout
                android:id="@+id/signalContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:background="#FFF3E0">

                <TextView
                    android:id="@+id/tvSignalMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:visibility="gone"
                    android:padding="8dp" />
            </LinearLayout>

            <!-- Current Location -->
            <TextView
                android:id="@+id/tvCurrentLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Location: Waiting for GPS..."
                android:layout_marginTop="8dp"
                android:padding="8dp"
                android:background="#E0E0E0" />

            <!-- Navigation Information -->
            <TextView
                android:id="@+id/tvCurrentPoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Target: --"
                android:layout_marginTop="8dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNextPoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Next: --"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvDistanceToNext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Distance to Next: -- m"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Progress: 0/6 points"
                android:layout_marginTop="4dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvApproachDistance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="End Point Alert Distance: 50m"
                android:layout_marginTop="4dp"
                android:textStyle="italic" />

            <!-- Route Status -->
            <TextView
                android:id="@+id/tvRouteStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Waiting for start"
                android:layout_marginTop="8dp"
                android:padding="8dp"
                android:background="#BBDEFB"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Not Tracking"
                android:layout_marginTop="4dp"
                android:textStyle="bold" />

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <Button
                    android:id="@+id/btnPauseTracking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pause Tracking"
                    android:layout_marginEnd="8dp"
                    android:enabled="false" />

                <Button
                    android:id="@+id/btnResumeTracking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Resume Tracking"
                    android:enabled="false" />
            </LinearLayout>

            <!-- Instructions -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Instructions:"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Service runs in background with notification\n2. Tracking starts automatically on app launch\n3. Use Pause/Resume to temporarily stop location updates\n4. Navigate through all route points in order\n5. Signal appears when within 50m of end point\n6. App continues tracking even when minimized"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>